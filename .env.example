# ================================================================================
# CONFIGURACIÓN DE NOTIFICACIONES POR EMAIL - SISEE
# ================================================================================
# Este archivo contiene las configuraciones necesarias para el envío de correos
# electrónicos del sistema de notificaciones.
#
# IMPORTANTE: 
# 1. Renombrar este archivo a .env
# 2. Completar con tus credenciales SMTP
# 3. NO subir este archivo a repositorios públicos (agregarlo a .gitignore)
# ================================================================================

# ================================================================================
# CONFIGURACIÓN SMTP (Servidor de Correo)
# ================================================================================

# Host del servidor SMTP
# Ejemplos comunes:
#   - Gmail: smtp.gmail.com
#   - Outlook/Hotmail: smtp-mail.outlook.com
#   - Yahoo: smtp.mail.yahoo.com
#   - Office 365: smtp.office365.com
SMTP_HOST=smtp.gmail.com

# Puerto SMTP
# Puertos comunes:
#   - 587 (TLS/STARTTLS - Recomendado)
#   - 465 (SSL)
#   - 25 (Sin encriptación - No recomendado)
SMTP_PORT=587

# Usuario SMTP (generalmente tu dirección de correo completa)
SMTP_USERNAME=tu-email@gmail.com

# Contraseña SMTP
# IMPORTANTE PARA GMAIL:
# Si usas Gmail, NO uses tu contraseña normal. Debes generar una "App Password":
# 1. Ve a tu cuenta de Google
# 2. Seguridad > Verificación en 2 pasos (activar si no está)
# 3. Seguridad > Contraseñas de aplicaciones
# 4. Generar nueva contraseña de aplicación
# 5. Usar esa contraseña aquí
SMTP_PASSWORD=tu-contraseña-o-app-password

# Email del remitente (From)
# Si no se especifica, se usa SMTP_USERNAME
SMTP_FROM_EMAIL=tu-email@gmail.com

# Nombre del remitente (From Name)
SMTP_FROM_NAME=Sistema de Gestión SISEE

# ================================================================================
# SEGURIDAD PARA CRON JOBS
# ================================================================================

# Token de seguridad para ejecutar cron jobs vía HTTP
# Generar un token aleatorio seguro (mínimo 32 caracteres)
# Ejemplo: openssl rand -hex 32
CRON_TOKEN=genera-un-token-aleatorio-muy-largo-y-seguro-aqui

# ================================================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ================================================================================

# URL base de la aplicación (para links en los correos)
APP_URL=https://tu-dominio.com

# ================================================================================
# INSTRUCCIONES DE CONFIGURACIÓN
# ================================================================================

# PARA GMAIL:
# ===========
# 1. Activar verificación en 2 pasos en tu cuenta de Google
# 2. Ir a: https://myaccount.google.com/apppasswords
# 3. Generar una contraseña de aplicación para "Correo"
# 4. Usar esa contraseña de 16 caracteres en SMTP_PASSWORD
#
# Configuración:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=tu-email@gmail.com
#   SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx (App Password de 16 caracteres)

# PARA OUTLOOK/HOTMAIL:
# =====================
# 1. Activar verificación en 2 pasos si es necesario
# 2. Permitir "aplicaciones menos seguras" si se solicita
#
# Configuración:
#   SMTP_HOST=smtp-mail.outlook.com
#   SMTP_PORT=587
#   SMTP_USERNAME=tu-email@outlook.com
#   SMTP_PASSWORD=tu-contraseña-de-outlook

# PARA YAHOO:
# ===========
# 1. Activar verificación en 2 pasos
# 2. Generar contraseña de aplicación
#
# Configuración:
#   SMTP_HOST=smtp.mail.yahoo.com
#   SMTP_PORT=587
#   SMTP_USERNAME=tu-email@yahoo.com
#   SMTP_PASSWORD=tu-app-password

# PARA OFFICE 365:
# ================
# Configuración:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USERNAME=tu-email@tuempresa.com
#   SMTP_PASSWORD=tu-contraseña

# PARA SERVIDORES SMTP PERSONALIZADOS:
# ====================================
# Consulta con tu proveedor de hosting los datos SMTP
# Configuración típica:
#   SMTP_HOST=mail.tu-dominio.com
#   SMTP_PORT=587 o 465
#   SMTP_USERNAME=notificaciones@tu-dominio.com
#   SMTP_PASSWORD=contraseña-del-correo

# ================================================================================
# PROBAR LA CONFIGURACIÓN
# ================================================================================
# Después de configurar, puedes probar el envío de correos:
# 1. Accede al sistema como usuario con rol de gestor (RolId = 9)
# 2. Ve a tu perfil/configuración
# 3. Configura tu email personal
# 4. Haz clic en "Enviar correo de prueba"
# 5. Revisa tu bandeja de entrada (y spam)
